{
  "name": "mini-md",
  "version": "1.0.0",
  "description": "A minimalist markdown website",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "pack": "npm pack",
    "move": "mv mini-md-1.0.0.tgz ./demo/",
    "build-demo": "npm run pack && npm run move && cd demo && npm remove mini-md && npm install mini-md-1.0.0.tgz && cd ..",
    "demo": "cd demo && npm start && cd ..",
    "generate-types": "tsc --declaration --emitDeclarationOnly --allowJs --checkJs --module esnext --target es6 --resolveJsonModule --allowSyntheticDefaultImports --moduleResolution node --outDir ./dist ./index.js",
    "prepublish": "npm run generate-types"
  },
  "bin": "./bin.js",
  "keywords": [],
  "author": "Frodi Karlsson",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "markdown-it": "^13.0.1",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-attrs": "^4.1.6",
    "markdown-it-checkbox": "^1.1.0",
    "mkdirp": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.8.2",
    "typescript": "^5.2.2"
  }
}
